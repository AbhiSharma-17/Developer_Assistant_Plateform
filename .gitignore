!.vscode/extensions.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# ── Uploads (keep folder, ignore files inside) ────────────
server/uploads/*
!server/uploads/.gitkeep

# ── Misc ──────────────────────────────────────────────────
*.local
.cache/
.temp/
